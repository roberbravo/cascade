      "title": "Media Móvil 12m ($/barril)",
      "type": "stat",
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT 1 as time, (data->'summary'->'current_trend'->>'ma_12m')::float as \"MA 12m\" FROM pipeline_results ORDER BY id DESC LIMIT 1",
          "format": "table"
        }
