{
  "title": "Cascade - Pipeline Results",
  "tags": [
    "cascade",
    "tfm"
  ],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "title": "Precio Medio Global ($/barril)",
      "type": "stat",
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT 1 as time, (data->'summary'->'global_statistics'->>'avg_price')::float as \"Precio Medio\" FROM pipeline_results ORDER BY id DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
