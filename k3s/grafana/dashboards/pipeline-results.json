    {
      "id": 5,
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "title": "Evolución Precio Petróleo por Año (1970-2026)",
      "type": "timeseries",
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT (value->>'year')::int * interval '1 year' + '1970-01-01'::date as time, (value->>'avg_price')::float as \"Precio Medio\", (value->>'max_price')::float as \"Precio Máximo\", (value->>'min_price')::float as \"Precio Mínimo\" FROM pipeline_results, jsonb_array_elements(data->'yearly_data') as value ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "title": "Anomalías Detectadas (Z-Score > 2.5)",
      "type": "table",
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT value->>'Date' as \"Fecha\", (value->>'Crude_Oil_Price')::float as \"Precio ($/barril)\", (value->>'Z_Score')::float as \"Z-Score\" FROM pipeline_results, jsonb_array_elements(data->'anomalies') as value ORDER BY (value->>'Crude_Oil_Price')::float DESC",
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 36,
